{
  agents: {
    defaults: {
      model: {
        primary: "simab/google/gemini-2.5-flash",
      },
      imageModel: {
        primary: "simab/google/gemini-2.5-flash",
      },
      models: {
        "simab/google/gemini-2.5-flash": {
          alias: "simab",
        },
      },
      thinkingDefault: "off",
      reasoningDefault: "off",
    },
    list: [
      {
        id: "product_manager",
        default: true,
        name: "Product Manager",
        model: {
          primary: "simab/google/gemini-2.5-flash",
        },
        skills: ["hypothesis-scorer", "mockup-generator"],
        thinkingDefault: "off",
        reasoningDefault: "off",
      },
      {
        id: "ux_designer",
        name: "UX Designer",
        model: {
          primary: "simab/google/gemini-2.5-flash",
        },
        skills: ["mockup-generator"],
      },
      {
        id: "ux_researcher",
        name: "UX Researcher",
        model: {
          primary: "simab/google/gemini-2.5-flash",
        },
        skills: ["hypothesis-scorer"],
      },
      {
        id: "critic",
        name: "Critic",
        model: {
          primary: "simab/google/gemini-2.5-flash",
        },
        skills: ["hypothesis-scorer"],
      },
    ],
  },
  gateway: {
    mode: "local",
    auth: {
      mode: "token",
    },
    http: {
      endpoints: {
        chatCompletions: {
          enabled: true,
        },
        responses: {
          enabled: true,
        },
      },
    },
  },
  models: {
    mode: "merge",
    providers: {
      simab: {
        baseUrl: "${SAB_REAL_BASE_URL}",
        apiKey: "${SAB_REAL_API_KEY}",
        api: "openai-completions",
        authHeader: true,
        models: [
          {
            id: "google/gemini-2.5-flash",
            name: "SimAB Gemini 2.5 Flash",
            reasoning: false,
            input: ["text", "image"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 1048576,
            contextTokens: 200000,
            maxTokens: 8192,
          },
        ],
      },
    },
  },
  skills: {
    load: {
      extraDirs: ["/home/node/.openclaw/skills"],
      watch: true,
    },
  },
}
